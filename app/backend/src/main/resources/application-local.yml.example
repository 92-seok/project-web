# 팀원이 로컬 개발 세팅 시 이 파일을 복사해서 application-local.yml 로 이름 변경 후 값 채워 사용
# cp application-local.yml.example application-local.yml
#
# 두 가지 주입 방식 중 선택:
#   1) 아래 기본값 자리(CHANGE_ME)를 직접 편집하여 사용
#   2) OS 환경변수(DB_URL / DB_USERNAME / DB_PASSWORD) 주입 — 기본값보다 우선 적용
#
# application-local.yml 은 .gitignore 로 커밋이 차단되어 있습니다.

spring:
  datasource:
    url: ${DB_URL:jdbc:mysql://127.0.0.1:3306/product_web?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Seoul&allowPublicKeyRetrieval=true&useSSL=false}
    username: ${DB_USERNAME:CHANGE_ME}
    password: ${DB_PASSWORD:CHANGE_ME}
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    show-sql: true
    properties:
      hibernate:
        format_sql: true

logging:
  level:
    org.springframework.web: INFO
    org.hibernate.SQL: DEBUG
    org.hibernate.orm.jdbc.bind: DEBUG
