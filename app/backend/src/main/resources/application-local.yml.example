# 팀원이 로컬 개발 세팅 시 이 파일을 복사해서 application-local.yml 로 이름 변경 후 값 채워 사용
# cp application-local.yml.example application-local.yml

spring:
  datasource:
    url: jdbc:mysql://127.0.0.1:3306/product_web?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia
/Seoul&allowPublicKeyRetrieval=true&useSSL=false
    username: CHANGE_ME
    password: CHANGE_ME
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    show-sql: true
    properties:
      hibernate:
        format_sql: true

logging:
  level:
    org.springframework.web: INFO
    org.hibernate.SQL: DEBUG
    org.hibernate.orm.jdbc.bind: TRACE
